generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Email {
  id           String    @id @default(cuid())
  crmContactId String
  contactName  String
  contactEmail String
  subject      String
  body         String
  tone         String?
  status       String    @default("draft")
  sentAt       DateTime?
  opened       Boolean   @default(false)
  openedAt     DateTime?
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  templateId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("draft")
  templateId  String?
  emails      Email[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id            String   @id @default(cuid())
  name          String
  subject       String
  body          String
  category      String?
  variables     String?
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
